<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ============================================================ -->
    <!-- PERMISOS DE UBICACIÓN (requeridos por geolocator y flutter_map) -->
    <!-- ============================================================ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Ubicación en segundo plano: necesaria para que la grabación no
         se corte cuando el usuario bloquea la pantalla mientras pedalea. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ============================================================ -->
    <!-- FOREGROUND SERVICE de ubicación (Android 9+ requiere el      -->
    <!-- permiso genérico; Android 14+ además exige el permiso de     -->
    <!-- tipo específico "location"). Sin esto, el servicio en primer -->
    <!-- plano de geolocator no puede arrancar.                        -->
    <!-- ============================================================ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Requerido por el foreground service para mantener el CPU        -->
    <!-- despierto y seguir recibiendo actualizaciones GPS mientras la    -->
    <!-- pantalla está bloqueada. Sin esto, geolocator falla en          -->
    <!-- silencio al intentar escuchar la posición en segundo plano.      -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- La notificación persistente que muestra el foreground service    -->
    <!-- ("Grabando actividad...") requiere este permiso en Android 13+.  -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ============================================================ -->
    <!-- PERMISOS DE BLUETOOTH (requeridos por flutter_blue_plus)      -->
    <!-- Android 12+ (API 31+) usa los nuevos permisos granulares.     -->
    <!-- Se mantienen los legacy para compatibilidad con versiones     -->
    <!-- anteriores de Android.                                        -->
    <!-- ============================================================ -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Declara que la app usa BLE, pero no lo hace estrictamente requerido -->
    <!-- (así el manifiesto no bloquea instalación en dispositivos sin BLE)  -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false" />

    <!-- ============================================================ -->
    <!-- FOTOS (requerido por image_picker en Android 12 o anterior;   -->
    <!-- en Android 13+ el selector del sistema no necesita permiso,   -->
    <!-- pero declararlo con maxSdkVersion mantiene compatibilidad     -->
    <!-- hacia atrás sin pedir un permiso de más en versiones nuevas). -->
    <!-- ============================================================ -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- ============================================================ -->
    <!-- INTERNET (requerido para descargar tiles del mapa y          -->
    <!-- sincronizar con el backend cuando haya conectividad)          -->
    <!-- ============================================================ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:label="cyclecore_app"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>